import Tetris.Types

namespace Tetris.Tetrominoes

-- ピボットからの相対オフセット (dr, dc): 各ミノ × 4 回転 × 4 セル
-- 90° CW 回転: (dr, dc) → (dc, -dr)
def shape : TetroType → Nat → Array (Int × Int)
  -- I: 横一列 / 縦一列
  | .I, 0 => #[(0,-1),(0,0),(0,1),(0,2)]
  | .I, 1 => #[(-1,0),(0,0),(1,0),(2,0)]
  | .I, 2 => #[(0,-1),(0,0),(0,1),(0,2)]
  | .I, 3 => #[(-1,0),(0,0),(1,0),(2,0)]
  -- O: 全回転で同一
  | .O, _ => #[(0,0),(0,1),(1,0),(1,1)]
  -- T
  | .T, 0 => #[(0,-1),(0,0),(0,1),(-1,0)]
  | .T, 1 => #[(-1,0),(0,0),(1,0),(0,1)]
  | .T, 2 => #[(0,-1),(0,0),(0,1),(1,0)]
  | .T, 3 => #[(-1,0),(0,0),(1,0),(0,-1)]
  -- S: .## / ##.
  | .S, 0 => #[(-1,0),(-1,1),(0,-1),(0,0)]
  | .S, 1 => #[(-1,0),(0,0),(0,1),(1,1)]
  | .S, 2 => #[(-1,0),(-1,1),(0,-1),(0,0)]
  | .S, 3 => #[(-1,0),(0,0),(0,1),(1,1)]
  -- Z: ##. / .##
  | .Z, 0 => #[(-1,-1),(-1,0),(0,0),(0,1)]
  | .Z, 1 => #[(-1,1),(0,0),(0,1),(1,0)]
  | .Z, 2 => #[(-1,-1),(-1,0),(0,0),(0,1)]
  | .Z, 3 => #[(-1,1),(0,0),(0,1),(1,0)]
  -- J: X.. / XXX
  | .J, 0 => #[(-1,-1),(0,-1),(0,0),(0,1)]
  | .J, 1 => #[(-1,0),(-1,1),(0,0),(1,0)]
  | .J, 2 => #[(0,-1),(0,0),(0,1),(1,1)]
  | .J, 3 => #[(-1,0),(0,0),(1,-1),(1,0)]
  -- L: ..X / XXX
  | .L, 0 => #[(-1,1),(0,-1),(0,0),(0,1)]
  | .L, 1 => #[(-1,0),(0,0),(1,0),(1,1)]
  | .L, 2 => #[(0,-1),(0,0),(0,1),(1,-1)]
  | .L, 3 => #[(-1,-1),(-1,0),(0,0),(1,0)]
  -- フォールバック（rotation は常に 0–3 のため到達しない）
  | _, _ => #[]

-- ANSI 背景色エスケープコード
def color : TetroType → String
  | .I => "\x1b[46m"
  | .O => "\x1b[43m"
  | .T => "\x1b[45m"
  | .S => "\x1b[42m"
  | .Z => "\x1b[41m"
  | .J => "\x1b[44m"
  | .L => "\x1b[103m"  -- Bright yellow (orange近似)

def allTypes : Array TetroType :=
  #[.I, .O, .T, .S, .Z, .J, .L]

end Tetris.Tetrominoes
